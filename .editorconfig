# =========================================================
# Synarius EditorConfig
# =========================================================

root = true

# ---------------------------------------------------------
# Default settings (all files)
# ---------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ---------------------------------------------------------
# Python
# ---------------------------------------------------------
[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

# ---------------------------------------------------------
# YAML / config files
# ---------------------------------------------------------
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ---------------------------------------------------------
# JSON
# ---------------------------------------------------------
[*.json]
indent_style = space
indent_size = 2

# ---------------------------------------------------------
# Markdown
# ---------------------------------------------------------
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ---------------------------------------------------------
# Shell scripts
# ---------------------------------------------------------
[*.sh]
indent_style = space
indent_size = 2

# ---------------------------------------------------------
# Windows batch
# ---------------------------------------------------------
[*.bat]
end_of_line = crlf