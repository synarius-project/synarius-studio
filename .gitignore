# =========================================================
# Python
# =========================================================
__pycache__/
*.py[cod]
*$py.class

.venv/
venv/
env/
ENV/

build/
dist/
*.egg-info/
.eggs/

# =========================================================
# Logs & temp
# =========================================================
*.log
*.tmp
*.temp
*.swp
*.swo

# =========================================================
# OS
# =========================================================
.DS_Store
Thumbs.db
desktop.ini

# =========================================================
# IDE
# =========================================================
.vscode/
.idea/

# =========================================================
# Testing / coverage
# =========================================================
.coverage
coverage.xml
htmlcov/
.pytest_cache/

# =========================================================
# Notebooks
# =========================================================
.ipynb_checkpoints/

# =========================================================
# Binaries
# =========================================================
*.so
*.dll
*.dylib
*.exe

# =========================================================
# Simulation / generated data
# =========================================================
/results/
/output/
/runs/
/data/generated/

# =========================================================
# Measurement data (ASAM MDF etc.)
# =========================================================
*.mf4
*.mdf
*.dat

# Allow small test data explicitly
!tests/data/
!tests/data/*.mf4
!tests/data/*.mdf
!tests/data/*.dat

# =========================================================
# Other data formats (large / generated)
# =========================================================
*.csv
*.hdf5
*.h5
*.mat

# Optional: allow example datasets
!examples/
!examples/**/*.csv
!examples/**/*.hdf5

# =========================================================
# FMU handling
# =========================================================
*.fmu.unpacked/
*.fmu.tmp/

# Optional: include FMUs if needed for examples
# *.fmu
# !examples/**/*.fmu

# =========================================================
# Local config
# =========================================================
.local/
config.local.*
settings.local.*

# =========================================================
# Secrets
# =========================================================
.env
.env.*
*.key
*.pem
*.secret