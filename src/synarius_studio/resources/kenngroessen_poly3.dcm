* Parametersatz 1: Kenngroessen mit kubischen Polynomfunktionen
*
* KL1  (Kennlinie 1): y = 0.001*x^3 - 0.05*x^2 + 1.5*x + 2.0
*                     x in [0, 50]
*
* KL2  (Kennlinie 2): y = -0.002*x^3 + 0.1*x^2 - 0.5*x + 3.0
*                     x in [-5, 20]
*
* KF1  (Kennfeld 1) : z = 0.001*x^3 - 0.002*y^3 + 0.5*x + 0.5*y + 1.0
*                     x in [0, 20],  y in [0, 20]
*
* KF2  (Kennfeld 2) : z = 0.0005*x^3 + 0.001*y^3 - 0.3*x + 0.2*y + 5.0
*                     x in [-10, 20], y in [0, 30]

KONSERVIERUNG_FORMAT 2.0

KENNLINIE KL1 6
 LANGNAME "Kennlinie 1 (kubisch)"
 EINHEIT -
 LANGNAME_X "Eingang x1"
 EINHEIT_X -
 ST/X 0.000 10.000 20.000 30.000 40.000 50.000
 WERT 2.000 13.000 20.000 29.000 46.000 77.000
END

KENNLINIE KL2 6
 LANGNAME "Kennlinie 2 (kubisch)"
 EINHEIT -
 LANGNAME_X "Eingang x2"
 EINHEIT_X -
 ST/X -5.000 0.000 5.000 10.000 15.000 20.000
 WERT 8.250 3.000 2.750 6.000 11.250 17.000
END

* KF1: z(x,y) = 0.001*x^3 - 0.002*y^3 + 0.5*x + 0.5*y + 1.0
* Achsen: x in [0,5,10,15,20], y in [0,5,10,15,20]
* Zeilenformat: ST/Y yi  WERT z(0,yi) z(5,yi) z(10,yi) z(15,yi) z(20,yi)
KENNFELD KF1 5 5
 LANGNAME "Kennfeld 1 (kubisch)"
 EINHEIT -
 LANGNAME_X "Eingang x1"
 EINHEIT_X -
 LANGNAME_Y "Eingang y1"
 EINHEIT_Y -
 ST/X 0.000 5.000 10.000 15.000 20.000
 ST/Y 0.000
 WERT 1.000 3.625 7.000 11.875 19.000
 ST/Y 5.000
 WERT 3.250 5.875 9.250 14.125 21.250
 ST/Y 10.000
 WERT 4.000 6.625 10.000 14.875 22.000
 ST/Y 15.000
 WERT 1.750 4.375 7.750 12.625 19.750
 ST/Y 20.000
 WERT -5.000 -2.375 1.000 5.875 13.000
END

* KF2: z(x,y) = 0.0005*x^3 + 0.001*y^3 - 0.3*x + 0.2*y + 5.0
* Achsen: x in [-10,0,10,20], y in [0,10,20,30]
* Zeilenformat: ST/Y yi  WERT z(-10,yi) z(0,yi) z(10,yi) z(20,yi)
KENNFELD KF2 4 4
 LANGNAME "Kennfeld 2 (kubisch)"
 EINHEIT -
 LANGNAME_X "Eingang x2"
 EINHEIT_X -
 LANGNAME_Y "Eingang y2"
 EINHEIT_Y -
 ST/X -10.000 0.000 10.000 20.000
 ST/Y 0.000
 WERT 7.500 5.000 2.500 3.000
 ST/Y 10.000
 WERT 10.500 8.000 5.500 6.000
 ST/Y 20.000
 WERT 19.500 17.000 14.500 15.000
 ST/Y 30.000
 WERT 40.500 38.000 35.500 36.000
END
